{
  "name": "contracts",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.2",
    "@nomicfoundation/hardhat-ignition": "^3.0.3",
    "@nomicfoundation/hardhat-verify": "^3.0.4",
    "@types/node": "^24.9.1",
    "hardhat": "^3.0.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5",
    "dotenv": "^17.2.1"
  },
  "scripts": {
    "start": "hardhat node",
    "test": "yarn run test:hardhat && yarn run test:forge",
    "test:coverage": "yarn test:hardhat:coverage && yarn test:forge:coverage",
    "test:forge": "forge test -vvv",
    "test:forge:coverage": "clear && forge coverage --report lcov && genhtml --ignore-errors inconsistent,corrupt --branch-coverage -o report lcov.info && open report/index.html",
    "test:hardhat": "NODE_ENV=test hardhat test",
    "test:hardhat:coverage": "NODE_ENV=test hardhat coverage",
    "format": "prettier --write 'contracts/**/*' 'test/**/*'",
    "format:check": "prettier --check 'contracts/**/*.sol'"
  }
}
