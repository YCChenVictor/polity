  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.75.7",
    "axios": "^1.10.0",
    "dotenv": "^17.2.3",
    "ethers": "^6.15.0",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.9.1",
    "react-scripts": "^5.0.1",
    "siwe": "^3.0.0",
    "viem": "^2.29.2",
    "wagmi": "^2.15.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vercel/node": "^5.5.5",
    "@vitejs/plugin-react": "^5.1.0",
    "@wagmi/cli": "^2.3.1",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-prettier": "^5.4.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "scripts": {
    "start:dev": "NODE_ENV=dev npx vercel dev",
    "generate": "wagmi generate",
    "lint": "yarn eslint .",
    "test": "vitest  --watch=false",
    "test:fix": "yarn test --run --bail=1",
    "test:coverage": "yarn test --coverage --verbose",
    "build": "tsc && tsc-alias",
    "format": "yarn eslint . --fix",
    "format:json": "yarn build && node dist/scripts/json-formatter.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
