{
  "name": "frontend",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.75.7",
    "axios": "^1.10.0",
    "ethers": "^6.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-scripts": "^5.0.1",
    "viem": "^2.29.2",
    "wagmi": "^2.15.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@wagmi/cli": "^2.3.1",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-prettier": "^5.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.2",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  },
  "scripts": {
    "start": "yarn generate && react-scripts start",
    "generate": "wagmi generate",
    "lint": "yarn eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --env=jsdom",
    "test:fix": "yarn test --bail",
    "test:coverage": "yarn test --coverage --verbose",
    "build": "tsc && tsc-alias",
    "format": "yarn eslint . --fix",
    "format:json": "yarn build && node dist/scripts/json-formatter.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
